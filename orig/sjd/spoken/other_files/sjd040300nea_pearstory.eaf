        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1080" ANNOTATION_REF="a710">
                <ANNOTATION_VALUE>Ну что я видела?</ANNOTATION_VALUE>
