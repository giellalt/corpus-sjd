                <ANNOTATION_VALUE>можно работать</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1094" ANNOTATION_REF="a724">
                <ANNOTATION_VALUE>Я вижу здесь дерево на растут</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1095" ANNOTATION_REF="a725">
                <ANNOTATION_VALUE>красивые</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1096" ANNOTATION_REF="a726">
                <ANNOTATION_VALUE>сладкие еда (мн.ч.)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1097" ANNOTATION_REF="a727">
                <ANNOTATION_VALUE>Эти русский языку надо сказать</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1098" ANNOTATION_REF="a728">
                <ANNOTATION_VALUE>по-саамски я не знаю как есть, русский языку есть груша</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1099" ANNOTATION_REF="a729">
                <ANNOTATION_VALUE>И мужчинa работаeт</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1100" ANNOTATION_REF="a730">
                <ANNOTATION_VALUE>одетый был</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1101" ANNOTATION_REF="a731">
                <ANNOTATION_VALUE>по-летнему и собирает груши-то</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1102" ANNOTATION_REF="a732">
                <ANNOTATION_VALUE>У него ещё лестница он лестница</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1103" ANNOTATION_REF="a733">
                <ANNOTATION_VALUE>по вверх туда поднимается и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1104" ANNOTATION_REF="a734">
                <ANNOTATION_VALUE>берёт</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1105" ANNOTATION_REF="a735">
                <ANNOTATION_VALUE>медленно битые</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1106" ANNOTATION_REF="a736">
                <ANNOTATION_VALUE>эти груши-то и свой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1107" ANNOTATION_REF="a737">
                <ANNOTATION_VALUE>фартук корман внутрь кладёт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1108" ANNOTATION_REF="a738">
                <ANNOTATION_VALUE>У него есть большой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1109" ANNOTATION_REF="a739">
                <ANNOTATION_VALUE>корман в фартуке, корман есть большой-большой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1110" ANNOTATION_REF="a740">
                <ANNOTATION_VALUE>и груши-то туда внутрь кладёт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1111" ANNOTATION_REF="a741">
                <ANNOTATION_VALUE>Тихонько, что не помять их или,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1112" ANNOTATION_REF="a742">
