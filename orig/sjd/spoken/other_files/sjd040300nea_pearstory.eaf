        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1092" ANNOTATION_REF="a722">
                <ANNOTATION_VALUE>утром не есть жарко</ANNOTATION_VALUE>
