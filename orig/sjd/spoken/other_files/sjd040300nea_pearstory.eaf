        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1113" ANNOTATION_REF="a743">
                <ANNOTATION_VALUE>Эти есть очень</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1114" ANNOTATION_REF="a744">
                <ANNOTATION_VALUE>мягкие же, как биться начнут,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1115" ANNOTATION_REF="a745">
                <ANNOTATION_VALUE>груши начнут</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1116" ANNOTATION_REF="a746">
                <ANNOTATION_VALUE>вянуть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1117" ANNOTATION_REF="a747">
                <ANNOTATION_VALUE>Но человек,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1118" ANNOTATION_REF="a748">
                <ANNOTATION_VALUE>я вижу, он есть собравши</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1119" ANNOTATION_REF="a749">
                <ANNOTATION_VALUE>два больших короба,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1120" ANNOTATION_REF="a750">
