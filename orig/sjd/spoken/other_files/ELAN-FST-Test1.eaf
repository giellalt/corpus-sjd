            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1787" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Адтҍ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1788" ANNOTATION_REF="a124" PREVIOUS_ANNOTATION="a1787">
                <ANNOTATION_VALUE>мыйй</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1789" ANNOTATION_REF="a124" PREVIOUS_ANNOTATION="a1788">
                <ANNOTATION_VALUE>тэ̄нн</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1790" ANNOTATION_REF="a124" PREVIOUS_ANNOTATION="a1789">
                <ANNOTATION_VALUE>сайй</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1791" ANNOTATION_REF="a124" PREVIOUS_ANNOTATION="a1790">
                <ANNOTATION_VALUE>коаххчель</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1792" ANNOTATION_REF="a124" PREVIOUS_ANNOTATION="a1791">
                <ANNOTATION_VALUE>Семёрка</ANNOTATION_VALUE>
            </REF_ANNOTATION>
