    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="orthT" PARENT_REF="ref" PARTICIPANT="GPL" TIER_ID="orth">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a123" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Касьт я̄ввьр Луявьр я По̄хп я̄ввьр пуэдтӭв э̄ххьт лӣ я̄вврь
                    рынтэсьт а̄в сайй – шӯрр кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Адтҍ мыйй тэ̄нн сайй коаххчель Семёрка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a125" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Тэ̄нн е̄ркъя кӣнтэсьт адтҍ мӯр шэнтэшкудтӭнҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Мӣн пуарса о̄ллмэ мушштсэллэв: е̄рка тэ̄нн саесьт ӣле э̄хт са̄мь
                    пӣрас – Егор ка̄ллесь Па̄ланҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a127" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Сӣненҍ ля̄й куэдтҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Куэла шылленҍ я пӯдзъятҍ пынненҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a129" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Илленҍ сыйй пуэраст.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Шоабшэнҍ куэсхэ ва̄р олмэтҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a131" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Па̄ла кӣннт лӣ шӯрр э̄лесь кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Выййт Па̄ла куэдӭсьт, вальшат я̄вр э̄л, пугк я̄ввьр куэсст, кукас
                    куэсст, ко̄з чалльн ва̄ллт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a133" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Тэсьт куэсст ко̄ххт я̄ввьр я̄лл, манҍтэ вэнс ко̄нн гоаррэ
                    ёадт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Па̄ла ю те̄дт, ке̄ лӣ вэ̄гсэсьт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a135" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Ӣнце пе̄ййввь а̄йкалт пэ̄йян я ве̄сьляхьтэшкуадт, е̄мьне
                    а̄втэшкуадт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Со̄а̄ййв пӣӈӈк пе̄ӈӈк, чӯшкэтҍ поасс, о̄лмэтҍ ев е̄кхэллче пырр
                    куэдҍ лыгкнэ оаллкэнҍ, кусетҍ прӣммэ, куэсь ке̄-не сыйе коавваст вайй кӣннт
                    сугкмэнҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a137" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>О̄ллмэ то̄а̄йв синэ̄нҍ лийенҍ, сыйтэсьт ёадтӭв, о̄дтэсьт пыххьтӭв,
                    ярьвесьт ёадтӭв, ижесь тӯе баяс мо̄а̄йнсэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a138" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Тэль мо̄а̄нсэв, куэснедтэв я тэ̄нн кэскэсьт шэ̄ӈат,
                    аббрай.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Сыйй вӯрьтэшкудтӭв, куэсь е̄ррк вуайхувв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Мудта вуэр ныдтҍ ко̄ллм пе̄йв мэ̄ннэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a141" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Ве̄сстлесь пе̄йв лийенҍ, куэсь о̄лмэ ё̄дьэнҍ мо̄а̄ст Пе̄дар пя̄йва
                    я Ыльй пя̄йва.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Ёадтӭв сыйй сыйта, пӣрсэтҍ выгкэв кӯле вэнс
                    тӣввт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a143" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Мудэнҍ гармошка мӣльтэ, танна тэсьт сӣрсэв,
                    плясъясьтэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Шоабэшт Па̄ла ижесь кӣннт, луэн сост ни касьт ев
                    лийй.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a145" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Мэ̄ннӭнҍ пе̄йв, мэ̄ннӭнҍ ыгь, Па̄ла ёаме.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Кӯдтэй калса о̄хтэ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a147" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Ле̄скэн олмне нюэссь лӣ е̄лле, но̄а̄йхьтлэдэ
                    Егор.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Чудзьявьр сыйтэсьт а̄хьк во̄а̄лльтэ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a149" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Тэ̄нн кӣннт о̄ллмэ коаччешкудтӭнҍ Па̄ла кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a150" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Мэ̄ннӭнҍ ыгь, пӯдӭ о̄дт я̄ллмушш.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a151" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Э̄лькенҍ о̄ллмэ тэсьт нӯххьтэ бригаданҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a152" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Кӯлле пуадт ныдтҍ е̄ннэ – кыджемь пӯдэ пуйхьц
                    тӣввт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a153" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Бригадасьт лийенҍ югкеналшэм о̄ллмэ: рӯшш, ыжэм, са̄мь, - пугк
                    сарнэшкудтӭнҍ рушас.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Тэсьт кыджемь пӯдт мӣльтэ ёадтэй одт нэ̄мм кӣнтэсьт:
                    Семёрка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a155" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Вай ныдтҍ ля̄й, вай мудта налла.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a156" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Мо̄а̄ййнсэв о̄лмэ вя̄л: Шӯрр туарр па̄ль тэ̄нн кӣнтэсьт ля̄й
                    военнэ часть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a157" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Сӣнэнҍ ля̄й лэ̄ӈӈкэм на̄ль.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a158" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Ке̄ те̄дт?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a159" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Ке̄ тедт…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a160" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Лэшэ пуарса о̄лмэ эффьтэ мушшьтэ тунн э̄втла нэ̄мм "Па̄ла
                    кӣннт".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="ft-rusT" PARENT_REF="orth" TIER_ID="ft-rus">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a162" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Где озеро Ловозеро и Поповское соединяются, есть на берегу
                    открытое место – большой луг.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a163" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Теперь мы это место зовем Семёрка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a164" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>На этом старом лугу деревья стали расти.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a165" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Наши старики вспоминают: в старину на этом месте жила одна
                    саамская семья – мужик Егор с Пелагеей.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a166" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>У них была вежа.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a167" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>Рыбку ловили и оленей держали.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a168" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>Жили они хорошо.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>Любили угощать дорожных людей.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a170" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>"Па̄ла кӣнт" – большой открытый луг на высоком
                    берегу.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a171" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>Выйдет Пелагея из вежи, посмотрит на озеро – все видно, далеко
                    видно, куда глаз хватит.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a172" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>Видно, как озеро живет, какая лодка в какую сторону
                    едет.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a173" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>А она уже знает, кто в лодке.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a174" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>Утром солнце рано подымается и вокруг веселей становится, землю
                    начинает греть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a175" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>Южный ветер подует, комаром сдует, людям не мешали бы работы
                    выполнять на улице вокруг вежи и гостей принимать, когда кто-нибудь завернет,
                    проезжая мимо их луга.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a176" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>Люди к ним часто заезжали. Из села едут, новости привезут, с озера
                    едут, о своих делах рассказыавают, угощаются,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a177" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>а в это время погода испортится, дождь пойдет.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a178" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE>Тогда будут ждать, когда погода сменится.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a179" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>В другой раз так три дня пройдет.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a180" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Веселые дни были, когда люди ехали домой на Петров день или на
                    Ильин день.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a181" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>Едут домой в село, семьями везут рыбы полную
                    лодку.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a182" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>У некоторых с собой гармошка, тогда здесь заиграют,
                    запляшут.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a183" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>Любила Пелагея свой луг, мусора у нее нигде не
                    было.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>Проходили дни, пролетали годы. Пелагея умерла.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a185" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE>Остался старик один.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a186" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>Вдовому человеку трудно дить одному, женился
                    Егор.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a187" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>В селе Чудзьявьре жену взял.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a188" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>Этот луг люди стали называть Пелагеин луг – Па̄ла
                    кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a189" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Прошли годы. Новая жизнь началась.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a190" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>Стали люди здесь неводом ловить рыбу, бригадой.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a191" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>Рыбы ловилось так много – семипудовая бочка
                    полная.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a192" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>В бригаде было много разных людей: русские, ком, саамы – все
                    говорили по-русски.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a193" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE>С этих времен новое имя Пелагеиному лугу "Па̄ла кӣннту" -
                    "Семёрка".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a194" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a195" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>Во время Великой отечественной войны на этом лугу стояла воинская
                    часть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a196" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE>У них позывной был "Семёрка". А может позывной был по названию
                    этого луга?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a197" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Как знать…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a198" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>как знать…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Но только старые люди все еще помнят первое название луга – Па̄ла
                    кӣннт, или по-русски сказать Луг Пелагеи.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="wordT" PARENT_REF="orth" TIER_ID="word">
