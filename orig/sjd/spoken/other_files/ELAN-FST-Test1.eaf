    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="orthT" PARENT_REF="ref" PARTICIPANT="GPL" TIER_ID="orth(original)">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a569" ANNOTATION_REF="a84">
                <ANNOTATION_VALUE>Касьт я̄ввьр Луявьр я По̄хп я̄ввьр пуэдтӭв э̄ххьт лӣ я̄вврь
                    рынтэсьт а̄в сайй – шӯрр кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a570" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>Адтҍ мыйй тэ̄нн сайй коаххчель Семёрка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a571" ANNOTATION_REF="a86">
                <ANNOTATION_VALUE>Тэ̄нн е̄ркъя кӣнтэсьт адтҍ мӯр шэнтэшкудтӭнҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a572" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>Мӣн пуарса о̄ллмэ мушштсэллэв: е̄рка тэ̄нн саесьт ӣле э̄хт са̄мь
                    пӣрас – Егор ка̄ллесь Па̄ланҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a573" ANNOTATION_REF="a88">
                <ANNOTATION_VALUE>Сӣненҍ ля̄й куэдтҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a574" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>Куэла шылленҍ я пӯдзъятҍ пынненҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a575" ANNOTATION_REF="a90">
                <ANNOTATION_VALUE>Илленҍ сыйй пуэраст.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a576" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>Шоабшэнҍ куэсхэ ва̄р олмэтҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a577" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>Па̄ла кӣннт лӣ шӯрр э̄лесь кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a578" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>Выййт Па̄ла куэдӭсьт, вальшат я̄вр э̄л, пугк я̄ввьр куэсст, кукас
                    куэсст, ко̄з чалльн ва̄ллт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a579" ANNOTATION_REF="a94">
                <ANNOTATION_VALUE>Тэсьт куэсст ко̄ххт я̄ввьр я̄лл, манҍтӭ вэнс ко̄нн гоаррэ
                    ёадт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a580" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>Па̄ла ю те̄дт, ке̄ лӣ вэ̄гсэсьт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a581" ANNOTATION_REF="a96">
                <ANNOTATION_VALUE>Ӣнце пе̄ййввь а̄йкалт пэ̄йян я ве̄сьляхьтӭшкуадт, е̄мьне
                    а̄втэшкуадт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a582" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Со̄а̄ййв пӣӈӈк пе̄ӈӈк, чӯшкэтҍ поасс, о̄лмэтҍ ев е̄кхэллче пырр
                    куэдҍ лыгкнэ оаллкэнҍ, кусетҍ прӣммэ, куэсь ке̄не сыйе коавваст вайй кӣннт
                    сугкмэнҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a583" ANNOTATION_REF="a98">
                <ANNOTATION_VALUE>О̄ллмэ то̄а̄йв синэ̄нҍ лийенҍ, сыйтэсьт ёадтӭв, о̄дтэсьтҍ
                    пыххьтӭв, ярьвесьт ёадтӭв, ижесь тӯе баяс мо̄а̄йнсэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a584" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>Тэль мо̄а̄нсэв, куэснедтэв я тэ̄нн кэскэсьт шэ̄ӈат,
                    аббрай.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a585" ANNOTATION_REF="a100">
                <ANNOTATION_VALUE>Сыйй вӯрьтӭшкудтӭв, куэсь е̄ррк вуайхувв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a586" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>Мудта вуэр ныдтҍ ко̄ллм пе̄йв мэ̄ннэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a587" ANNOTATION_REF="a102">
                <ANNOTATION_VALUE>Ве̄сстлесь пе̄йв лийенҍ, куэсь о̄лмэ ё̄дьэнҍ мо̄а̄ст Пе̄дар пя̄йва
                    я Ыльй пя̄йва.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a588" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>Ёадтӭв сыйй сыйта, пӣрсэтҍ выгкэв кӯле вэнс
                    тӣввт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a589" ANNOTATION_REF="a104">
                <ANNOTATION_VALUE>Мудэнҍ гармошка мӣльтӭ, танна тэсьт сӣрсэв,
                    плясъясьтэв.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a590" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>Шоабэшт Па̄ла ижесь кӣннт, луэн сост ни касьт ев
                    лийй.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a591" ANNOTATION_REF="a106">
                <ANNOTATION_VALUE>Мэ̄ннӭнҍ пе̄йв, мэ̄ннӭнҍ ыгь, Па̄ла ёаме.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a592" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>Кӯдтэй калса о̄хтэ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a593" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Ле̄скэн олмне нюэссь лӣ е̄лле, но̄а̄йхьтлэдэ
                    Егор.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a594" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>Чудзьявьр сыйтэсьт а̄хьк во̄а̄лльтӭ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a595" ANNOTATION_REF="a110">
                <ANNOTATION_VALUE>Тэ̄нн кӣннт о̄ллмэ коаччешкудтӭнҍ Па̄ла кӣннт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a596" ANNOTATION_REF="a111">
                <ANNOTATION_VALUE>Мэ̄ннӭнҍ ыгь, пӯдӭ о̄дт я̄ллмушш.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a597" ANNOTATION_REF="a112">
                <ANNOTATION_VALUE>Э̄лькенҍ о̄ллмэ тэсьт нӯххьтӭ бригаданҍ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a598" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>Кӯлле пуадт ныдт е̄ннэ – кыджемь пӯдэ пуйхьц
                    тӣввт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a599" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>Бригадасьт лийенҍ югкеналшэм о̄ллмэ: рӯшш, ыжэм, са̄мь, – пугк
                    сарнэшкудтӭнҍ рушас.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a600" ANNOTATION_REF="a115">
                <ANNOTATION_VALUE>Тэсьт кыджемь пӯдт мӣльтӭ ёадтэй одт нэ̄мм кӣнтэсьт:
                    Семёрка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a601" ANNOTATION_REF="a116">
                <ANNOTATION_VALUE>Вай ныдтҍ ля̄й, вай мудта налла.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a602" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Мо̄а̄ййнсэв о̄лмэ вя̄л: Шӯрр туарр па̄ль тэ̄нн кӣнтэсьт ля̄й
                    военнэ часть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a603" ANNOTATION_REF="a118">
                <ANNOTATION_VALUE>Сӣнэнҍ ля̄й лэ̄ӈӈкэм на̄ль.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a604" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>Ке̄ те̄дт?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a605" ANNOTATION_REF="a120">
                <ANNOTATION_VALUE>Ке̄ тедт…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a606" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>Лэшэ пуарса о̄лмэ эффьтӭ мушшьтӭ тунн э̄втла нэ̄мм "Па̄ла
                    кӣннт".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="posT" PARENT_REF="word" PARTICIPANT="GPL" TIER_ID="pos"/>
    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="ft-engT" PARENT_REF="orth" PARTICIPANT="GPL" TIER_ID="ft-eng">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1732" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>There is an open place on the shore where the lakes Lovozero and
                    Popovskoe meet – a big ??.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1733" ANNOTATION_REF="a124">
                <ANNOTATION_VALUE>Now we call this place Semjërka ("Number
                    Seven").</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1734" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>At this old ?? once there grew a settlement. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1735" ANNOTATION_REF="a126">
                <ANNOTATION_VALUE>Our elders remember: In the past there lived a Saami family at
                    this place – the man ?? with ??.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1736" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>They had a hut.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1737" ANNOTATION_REF="a128">
                <ANNOTATION_VALUE>They caught fish and kept reindeer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1738" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>They lived good.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1739" ANNOTATION_REF="a130">
                <ANNOTATION_VALUE>They liked to host travellers.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1740" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>"Pāla kīnnt" means a large open ?? on the high
                    shore.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1741" ANNOTATION_REF="a132">
                <ANNOTATION_VALUE>P?? leaves the hut, looks over the lake – she has the whole lake
                    in her view, far away, as far as her eyes reach. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1742" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>It is visable how the lake lives, which boat is sailing to what
                    side.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1743" ANNOTATION_REF="a134">
                <ANNOTATION_VALUE>And she knows already who is in the boat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1744" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>In the morning the sun rises early and makes one gladsomely, the
                    earth starts warming up.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1745" ANNOTATION_REF="a136">
                <ANNOTATION_VALUE>There is a southern breeze, the moscitos ?? not worry the people
                    who work outside and wait for the guests, when </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1746" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>People came regularly to visit them. They come from the fillage,
                    bringing the news. They come from the lake, telling about their work, ??.
                </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1747" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1748" ANNOTATION_REF="a139">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1749" ANNOTATION_REF="a140">
                <ANNOTATION_VALUE>Another time three days went.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1750" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>It where happy days, when people went home ??</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1751" ANNOTATION_REF="a142">
                <ANNOTATION_VALUE>They go home to the village, bring their families the boat full of
                    fish.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1752" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>Some bring along an accordion. Then they play at the place, they
                    dance.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1753" ANNOTATION_REF="a144">
                <ANNOTATION_VALUE>P?? loved her ??, there was no garbage
                    anywhere.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1754" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>The days went, the years flew by. P?? passed
                    away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1755" ANNOTATION_REF="a146">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1756" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>The grieving man </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1757" ANNOTATION_REF="a148">
                <ANNOTATION_VALUE>He took a woman from the village of
                    Čudz'jāvv'r.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1758" ANNOTATION_REF="a149">
                <ANNOTATION_VALUE>People started calling this ?? "Pāla kīnnt" –
                    ??</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1759" ANNOTATION_REF="a150">
                <ANNOTATION_VALUE>Years passed by. The new live begun.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1760" ANNOTATION_REF="a151">
                <ANNOTATION_VALUE>People started to fish with nets, in a brigade.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1761" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1762" ANNOTATION_REF="a153">
                <ANNOTATION_VALUE>There were different people in the brigade: Russians, Izhvatas,
                    Saami – they all started speaking Russian.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1763" ANNOTATION_REF="a154">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1764" ANNOTATION_REF="a155">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1765" ANNOTATION_REF="a156">
                <ANNOTATION_VALUE>The people also remember: </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1766" ANNOTATION_REF="a157">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1767" ANNOTATION_REF="a158">
                <ANNOTATION_VALUE>Who knows?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1768" ANNOTATION_REF="a159">
                <ANNOTATION_VALUE>Who knows…</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1769" ANNOTATION_REF="a160">
                <ANNOTATION_VALUE>Only the old people still remember this first name "Pāla
                    kīnnt".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
