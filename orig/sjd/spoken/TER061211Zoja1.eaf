        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2982" ANNOTATION_REF="a977">
                <ANNOTATION_VALUE>nu andrej varadi tōga a sōnne sārni što snačala po mestu žitel'stva nado sxodit'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2983" ANNOTATION_REF="a981">
                <ANNOTATION_VALUE>čto otkuda oni bɨli kōs' lien' i kōs' sɨjj pedted</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2984" ANNOTATION_REF="a982">
