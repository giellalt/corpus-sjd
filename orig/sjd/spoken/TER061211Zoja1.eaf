        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3114" ANNOTATION_REF="a1080">
                <ANNOTATION_VALUE>mān pijj čaj ne</ANNOTATION_VALUE>
