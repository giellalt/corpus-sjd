            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2985" ANNOTATION_REF="a987">
                <ANNOTATION_VALUE>pɨmm'aj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2986" ANNOTATION_REF="a988">
                <ANNOTATION_VALUE>ot tol'ko munn zabɨla v kakom klasse munn učilas' ja znaju čto must</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2987" ANNOTATION_REF="a992">
                <ANNOTATION_VALUE>vnuk-tp prijd'ot priedet-to tak sōnn kāvn pakas'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2988" ANNOTATION_REF="a993">
                <ANNOTATION_VALUE>val't tomal't tapki musst</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2989" ANNOTATION_REF="a998">
                <ANNOTATION_VALUE>kāvnik vot taki</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2990" ANNOTATION_REF="a1001">
                <ANNOTATION_VALUE>po. eto podterpe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2991" ANNOTATION_REF="a1002">
                <ANNOTATION_VALUE>tedt' uže porkea sobeiraets'a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2992" ANNOTATION_REF="a1003">
                <ANNOTATION_VALUE>kōz tɨjj porkebpe oaz'- oarrhe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2993" ANNOTATION_REF="a1004">
                <ANNOTATION_VALUE>porkes'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2994" ANNOTATION_REF="a1005">
                <ANNOTATION_VALUE>net ona govorit zam'orzla ja govor'u a vɨ čto uže porkebpe</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2995" ANNOTATION_REF="a1006">
                <ANNOTATION_VALUE>vot da ned govorit ebpe porket nu munn kīč čain</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2996" ANNOTATION_REF="a1007">
                <ANNOTATION_VALUE>čaj seičas čaj ničevo ja tut vɨtru vs'o čto xot' peden</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2997" ANNOTATION_REF="a1008">
                <ANNOTATION_VALUE>oarbit</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2998" ANNOTATION_REF="a1010">
                <ANNOTATION_VALUE>kto za mnoj ubiraet v podoždi ke leaj pedteli</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2999" ANNOTATION_REF="a1012">
                <ANNOTATION_VALUE>net tajta pued' tajta i taki</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3000" ANNOTATION_REF="a1013">
                <ANNOTATION_VALUE>pɨlesbornik leg sān' pɨlesbornik tajt mumm īǯ pokas' kopčam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3001" ANNOTATION_REF="a1014">
                <ANNOTATION_VALUE>nu kōxxt pɨlesosom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3002" ANNOTATION_REF="a1015">
                <ANNOTATION_VALUE>līj uckaj līj no līj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3003" ANNOTATION_REF="a1016">
                <ANNOTATION_VALUE>paslam tože īǯ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3004" ANNOTATION_REF="a1017">
                <ANNOTATION_VALUE>poka īǯ pokas't tagam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3005" ANNOTATION_REF="a1018">
                <ANNOTATION_VALUE>mom voajam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3006" ANNOTATION_REF="a1019">
                <ANNOTATION_VALUE>a kez- a voobšče nantam takem lanivaj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3007" ANNOTATION_REF="a1024">
                <ANNOTATION_VALUE>ēdt'a esli men'a razbudi</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3008" ANNOTATION_REF="a1025">
                <ANNOTATION_VALUE>ēdt'a a tōnn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3009" ANNOTATION_REF="a1027">
                <ANNOTATION_VALUE>nu ku- kukas' čitue oadam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3010" ANNOTATION_REF="a1028">
                <ANNOTATION_VALUE>i tut i ākaj sverxu zv-</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3011" ANNOTATION_REF="a1029">
                <ANNOTATION_VALUE>mūnn podn'ala govor'u mējt tunne pɨdte</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3012" ANNOTATION_REF="a1030">
                <ANNOTATION_VALUE>oj da vot velgak egk magazimɨmp'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3013" ANNOTATION_REF="a1031">
                <ANNOTATION_VALUE>eto aga lavka</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3014" ANNOTATION_REF="a1032">
                <ANNOTATION_VALUE>mɨnne lejpa bɨdt esÄte mɨnne kuricu bɨdt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3015" ANNOTATION_REF="a1033">
                <ANNOTATION_VALUE>kōz gin' imm vɨl'k</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3016" ANNOTATION_REF="a1034">
                <ANNOTATION_VALUE>munn oadam veal kot' oadam dvenadcat' časov</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3017" ANNOTATION_REF="a1035">
                <ANNOTATION_VALUE>nu tak skol'ko pedt skol'ko i aodam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3018" ANNOTATION_REF="a1041">
                <ANNOTATION_VALUE>a kop' dočka ākta to dak</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3019" ANNOTATION_REF="a1042">
                <ANNOTATION_VALUE>nɨdt' lɨs't vartaj kon tam ja ānnas't tegešte </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3020" ANNOTATION_REF="a1044">
                <ANNOTATION_VALUE>a munn sōne sārnej govor'u učti</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3021" ANNOTATION_REF="a1045">
                <ANNOTATION_VALUE>must kɨdtej tol'ko polovina</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3022" ANNOTATION_REF="a1046">
                <ANNOTATION_VALUE>tōnn dumaeš čto munn pro- tɨn īges'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3023" ANNOTATION_REF="a1047">
                <ANNOTATION_VALUE>pokas't pr'amo da po muzejam veal vardim</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3024" ANNOTATION_REF="a1048">
                <ANNOTATION_VALUE>a adt' lar'ek imm vuaj vard'a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3086" ANNOTATION_REF="a1049">
                <ANNOTATION_VALUE>kon- tam v muzej tel'ki čto vot na mašine i vs'o</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3087" ANNOTATION_REF="a1050">
                <ANNOTATION_VALUE>nu drug na mašine uexal čto-to ne podajot znak pačink ili mājt</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3088" ANNOTATION_REF="a1051">
                <ANNOTATION_VALUE>nu tak oj nɨdt' paj a kōs' sōnn mūn vɨgk- mun sōn vɨktinta oj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3093" ANNOTATION_REF="a1052">
                <ANNOTATION_VALUE>nu mējt nu začem munn pačkap</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3094" ANNOTATION_REF="a1053">
                <ANNOTATION_VALUE>sōnn tože pačkim olmej līj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3095" ANNOTATION_REF="a1054">
                <ANNOTATION_VALUE>veal kɨll sōnne pɨdtaj šɨlle</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3096" ANNOTATION_REF="a1055">
                <ANNOTATION_VALUE>kon tamp- kɨllet šɨlle vārr</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3097" ANNOTATION_REF="a1056">
                <ANNOTATION_VALUE>ākkaj vārre perrhte</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3098" ANNOTATION_REF="a1057">
                <ANNOTATION_VALUE>īǯant perrhte īǯant ākaj ākagos't a munn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3099" ANNOTATION_REF="a1058">
                <ANNOTATION_VALUE>oj nu i vutkimp</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3100" ANNOTATION_REF="a1060">
                <ANNOTATION_VALUE>a kuda jesli ja čto zaxoču tak vs'o ravno tak nɨdt' kot' munn xoču</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3101" ANNOTATION_REF="a1061">
                <ANNOTATION_VALUE>i tages'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3102" ANNOTATION_REF="a1062">
                <ANNOTATION_VALUE>vɨl'li oj kak ja teper' budu a ničego očen' soskučišs'a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3103" ANNOTATION_REF="a1067">
                <ANNOTATION_VALUE>vesnoj letom togda jest' i a tōnn tagza perrhst</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3104" ANNOTATION_REF="a1068">
                <ANNOTATION_VALUE>a jesli čal'gua jesli ɨnne čālk</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3105" ANNOTATION_REF="a1069">
                <ANNOTATION_VALUE>i ozvoniš konečno munn tōnne gur'tem puadam</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3106" ANNOTATION_REF="a1070">
                <ANNOTATION_VALUE>tānn'u tōnn mašinan' pued' jesli puadt mašinan' tak vil'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3107" ANNOTATION_REF="a1071">
                <ANNOTATION_VALUE>ɨgk la ujmen'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3108" ANNOTATION_REF="a1072">
                <ANNOTATION_VALUE>a tes't igk yjn nimenč</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3109" ANNOTATION_REF="a1073">
                <ANNOTATION_VALUE>imm vuezmelmen'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3110" ANNOTATION_REF="a1075">
                <ANNOTATION_VALUE>kōz pējtmen'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3111" ANNOTATION_REF="a1077">
                <ANNOTATION_VALUE>tās' sejčas kavnamp'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3112" ANNOTATION_REF="a3091">
                <ANNOTATION_VALUE>tak</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3113" ANNOTATION_REF="a1079">
                <ANNOTATION_VALUE>a īǯ' igk kāvn</ANNOTATION_VALUE>
