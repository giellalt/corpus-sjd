            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2968" ANNOTATION_REF="a831">
                <ANNOTATION_VALUE>nu najt- kōz to to na juga to</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2969" ANNOTATION_REF="a956">
                <ANNOTATION_VALUE>a eto āǯ mūn āǯ ja sōnn leaj pastux sost leaj čēdaj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2970" ANNOTATION_REF="a957">
                <ANNOTATION_VALUE>kuz- ke sōn čedejt i sonn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2971" ANNOTATION_REF="a959">
                <ANNOTATION_VALUE>a nɨdt' sōnn</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2972" ANNOTATION_REF="a960">
                <ANNOTATION_VALUE>ne rvals'a a sōnn tēlki pedcij tīge</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2973" ANNOTATION_REF="a961">
                <ANNOTATION_VALUE>sōnn'e tel'ki pueǯɨ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2974" ANNOTATION_REF="a962">
                <ANNOTATION_VALUE>ne daju sōnn pīkas't pueǯej t°ede a tundru sōnn kōxxt tēde</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2975" ANNOTATION_REF="a963">
                <ANNOTATION_VALUE>oj každɨj každɨj kačok kločok tomal't pakas'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2976" ANNOTATION_REF="a964">
                <ANNOTATION_VALUE>geologi pedtin'</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2977" ANNOTATION_REF="a965">
                <ANNOTATION_VALUE>a v škole ja v škole maxtim must imm tī des'atɨj klass ili dev'atɨj klass</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2978" ANNOTATION_REF="a969">
                <ANNOTATION_VALUE>a kakoe nasledstvo da kējve</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2979" ANNOTATION_REF="a974">
                <ANNOTATION_VALUE>i tōn ded zaveščanie čāli</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2980" ANNOTATION_REF="a975">
                <ANNOTATION_VALUE>a eto oʒkuadak tak i v arktičeskom</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2981" ANNOTATION_REF="a976">
                <ANNOTATION_VALUE>i oʒ</ANNOTATION_VALUE>
