                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1080" ANNOTATION_REF="a710">
                <ANNOTATION_VALUE>Ну что я видела?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1081" ANNOTATION_REF="a711">
                <ANNOTATION_VALUE>Я видела</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1082" ANNOTATION_REF="a712">
                <ANNOTATION_VALUE>это утром рано</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1083" ANNOTATION_REF="a713">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1084" ANNOTATION_REF="a714">
                <ANNOTATION_VALUE>не ещё большой день с солнцем восходит.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1085" ANNOTATION_REF="a715">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1086" ANNOTATION_REF="a716">
                <ANNOTATION_VALUE>Мало есть ещё</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1087" ANNOTATION_REF="a717">
                <ANNOTATION_VALUE>тёмный (сумерки)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1088" ANNOTATION_REF="a718">
                <ANNOTATION_VALUE>Это утро есть,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1089" ANNOTATION_REF="a719">
                <ANNOTATION_VALUE>слышно петух там кричит</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1090" ANNOTATION_REF="a720">
                <ANNOTATION_VALUE>людей будит</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1091" ANNOTATION_REF="a721">
                <ANNOTATION_VALUE>Петух кричит слышат просыпаются</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1092" ANNOTATION_REF="a722">
                <ANNOTATION_VALUE>утром не есть жарко</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1093" ANNOTATION_REF="a723">
                <ANNOTATION_VALUE>можно работать</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1094" ANNOTATION_REF="a724">
                <ANNOTATION_VALUE>Я вижу здесь дерево на растут</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1095" ANNOTATION_REF="a725">
                <ANNOTATION_VALUE>красивые</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1096" ANNOTATION_REF="a726">
                <ANNOTATION_VALUE>сладкие еда (мн.ч.)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1097" ANNOTATION_REF="a727">
                <ANNOTATION_VALUE>Эти русский языку надо сказать</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1098" ANNOTATION_REF="a728">
                <ANNOTATION_VALUE>по-саамски я не знаю как есть, русский языку есть груша</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1099" ANNOTATION_REF="a729">
                <ANNOTATION_VALUE>И мужчинa работаeт</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1100" ANNOTATION_REF="a730">
                <ANNOTATION_VALUE>одетый был</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1101" ANNOTATION_REF="a731">
                <ANNOTATION_VALUE>по-летнему и собирает груши-то</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1102" ANNOTATION_REF="a732">
                <ANNOTATION_VALUE>У него ещё лестница он лестница</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1103" ANNOTATION_REF="a733">
                <ANNOTATION_VALUE>по вверх туда поднимается и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1104" ANNOTATION_REF="a734">
                <ANNOTATION_VALUE>берёт</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1105" ANNOTATION_REF="a735">
                <ANNOTATION_VALUE>медленно битые</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1106" ANNOTATION_REF="a736">
                <ANNOTATION_VALUE>эти груши-то и свой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1107" ANNOTATION_REF="a737">
                <ANNOTATION_VALUE>фартук корман внутрь кладёт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1108" ANNOTATION_REF="a738">
                <ANNOTATION_VALUE>У него есть большой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1109" ANNOTATION_REF="a739">
                <ANNOTATION_VALUE>корман в фартуке, корман есть большой-большой</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1110" ANNOTATION_REF="a740">
                <ANNOTATION_VALUE>и груши-то туда внутрь кладёт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1111" ANNOTATION_REF="a741">
                <ANNOTATION_VALUE>Тихонько, что не помять их или,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1112" ANNOTATION_REF="a742">
                <ANNOTATION_VALUE>или побить эти.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1113" ANNOTATION_REF="a743">
                <ANNOTATION_VALUE>Эти есть очень</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1114" ANNOTATION_REF="a744">
                <ANNOTATION_VALUE>мягкие же, как биться начнут,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1115" ANNOTATION_REF="a745">
                <ANNOTATION_VALUE>груши начнут</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1116" ANNOTATION_REF="a746">
                <ANNOTATION_VALUE>вянуть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1117" ANNOTATION_REF="a747">
                <ANNOTATION_VALUE>Но человек,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1118" ANNOTATION_REF="a748">
                <ANNOTATION_VALUE>я вижу, он есть собравши</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1119" ANNOTATION_REF="a749">
                <ANNOTATION_VALUE>два больших короба,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1120" ANNOTATION_REF="a750">
                <ANNOTATION_VALUE>полные положенные груши-то.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1121" ANNOTATION_REF="a751">
                <ANNOTATION_VALUE>Вверх поднялся,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1122" ANNOTATION_REF="a752">
                <ANNOTATION_VALUE>добавил ещё</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1123" ANNOTATION_REF="a753">
                <ANNOTATION_VALUE>собранные груши-то, положил</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1124" ANNOTATION_REF="a754">
                <ANNOTATION_VALUE>так тихонько, кладёт, чтобы их не побить,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1125" ANNOTATION_REF="a755">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1126" ANNOTATION_REF="a756">
                <ANNOTATION_VALUE>мягкая еда груши-то.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1127" ANNOTATION_REF="a757">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1128" ANNOTATION_REF="a758">
                <ANNOTATION_VALUE>И опять залез трап (лестница) на</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1129" ANNOTATION_REF="a759">
                <ANNOTATION_VALUE>гладкие собирает</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1130" ANNOTATION_REF="a760">
                <ANNOTATION_VALUE>груши, кладёт корман внутрь.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1131" ANNOTATION_REF="a761">
                <ANNOTATION_VALUE>Мимо</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1132" ANNOTATION_REF="a762">
                <ANNOTATION_VALUE>этот же час</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1133" ANNOTATION_REF="a763">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1134" ANNOTATION_REF="a764">
                <ANNOTATION_VALUE>другой человек идёт,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1135" ANNOTATION_REF="a765">
                <ANNOTATION_VALUE>козу следом тянет , </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1136" ANNOTATION_REF="a766">
                <ANNOTATION_VALUE>там коза кричит,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1137" ANNOTATION_REF="a767">
                <ANNOTATION_VALUE>ну как по-овечьи</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1138" ANNOTATION_REF="a768">
                <ANNOTATION_VALUE>блеет.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1139" ANNOTATION_REF="a769">
                <ANNOTATION_VALUE>Коза голос подаёт, что</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1140" ANNOTATION_REF="a770">
                <ANNOTATION_VALUE>куда-то её ведут,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1141" ANNOTATION_REF="a771">
                <ANNOTATION_VALUE>но думает же она, ведут туда</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1142" ANNOTATION_REF="a772">
                <ANNOTATION_VALUE>куда-нибудь приивязать</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1143" ANNOTATION_REF="a773">
                <ANNOTATION_VALUE>сено и траву еды для</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1144" ANNOTATION_REF="a774">
                <ANNOTATION_VALUE>козы-то.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1145" ANNOTATION_REF="a775">
                <ANNOTATION_VALUE>Женщин здесь не видно, лишь виднеются мужчины есть</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1146" ANNOTATION_REF="a776">
                <ANNOTATION_VALUE>один мужчина груши собирает, второй - с козой идёт.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1147" ANNOTATION_REF="a777">
                <ANNOTATION_VALUE>А мимо едет</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1148" ANNOTATION_REF="a778">
                <ANNOTATION_VALUE>велосипед на</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1149" ANNOTATION_REF="a779">
                <ANNOTATION_VALUE>мальчик.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1150" ANNOTATION_REF="a780">
                <ANNOTATION_VALUE>Пришёл,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1151" ANNOTATION_REF="a781">
                <ANNOTATION_VALUE>смотрит у-</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1152" ANNOTATION_REF="a782">
                <ANNOTATION_VALUE>столько груш собравший есть человек и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1153" ANNOTATION_REF="a783">
                <ANNOTATION_VALUE>вверх заглянул,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1154" ANNOTATION_REF="a784">
                <ANNOTATION_VALUE>далеко там не видит идёт он.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1155" ANNOTATION_REF="a785">
                <ANNOTATION_VALUE>И он хотел одну грушу взять,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1156" ANNOTATION_REF="a786">
                <ANNOTATION_VALUE>съесть ли, своровать ли, я не знаю.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1157" ANNOTATION_REF="a787">
                <ANNOTATION_VALUE>Смотрит,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1158" ANNOTATION_REF="a788">
                <ANNOTATION_VALUE>схватил одну, мало есть его.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1159" ANNOTATION_REF="a789">
                <ANNOTATION_VALUE>Он тогда</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1160" ANNOTATION_REF="a790">
                <ANNOTATION_VALUE>схватил полный короб с собой,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1161" ANNOTATION_REF="a791">
                <ANNOTATION_VALUE>положил впереди себя туда,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1162" ANNOTATION_REF="a792">
                <ANNOTATION_VALUE>велосипед на</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1163" ANNOTATION_REF="a793">
                <ANNOTATION_VALUE>и ушёл прочь.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1164" ANNOTATION_REF="a794">
                <ANNOTATION_VALUE>Дорога по едет едет (быстро), дорога эта есть</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1165" ANNOTATION_REF="a795">
                <ANNOTATION_VALUE>не есть асфальтовая дорога,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1166" ANNOTATION_REF="a796">
                <ANNOTATION_VALUE>сельская дорога</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1167" ANNOTATION_REF="a797">
                <ANNOTATION_VALUE>много камней есть</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1168" ANNOTATION_REF="a798">
                <ANNOTATION_VALUE>Навстречу ему придёт девочка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1169" ANNOTATION_REF="a799">
                <ANNOTATION_VALUE>Мальчик девочка на заглянул, заглянул и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1170" ANNOTATION_REF="a800">
                <ANNOTATION_VALUE>в камень зацепился, и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1171" ANNOTATION_REF="a801">
                <ANNOTATION_VALUE>упал, и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1172" ANNOTATION_REF="a802">
                <ANNOTATION_VALUE>груши все у него</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1173" ANNOTATION_REF="a803">
                <ANNOTATION_VALUE>дороге по перевернулись,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1174" ANNOTATION_REF="a804">
                <ANNOTATION_VALUE>рассыпались.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1175" ANNOTATION_REF="a805">
                <ANNOTATION_VALUE>А сам сел, ногу есть ушиб,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1176" ANNOTATION_REF="a806">
                <ANNOTATION_VALUE>смотрит на, ногу стал поправлять (-кудӭ , -гудӭ , -шкудэ - озн. начало действия)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1177" ANNOTATION_REF="a807">
                <ANNOTATION_VALUE>И мимо шли,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1178" ANNOTATION_REF="a808">
                <ANNOTATION_VALUE>недалеко сидели</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1179" ANNOTATION_REF="a809">
                <ANNOTATION_VALUE>три мальчишки,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1180" ANNOTATION_REF="a810">
                <ANNOTATION_VALUE>эти видят, что беда есть мальчишке стала.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1181" ANNOTATION_REF="a811">
                <ANNOTATION_VALUE>Тогда они</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1182" ANNOTATION_REF="a812">
                <ANNOTATION_VALUE>пришли к нему, подошли к нему,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1183" ANNOTATION_REF="a813">
                <ANNOTATION_VALUE>собрали груши-то, положили короб внутрь,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1184" ANNOTATION_REF="a814">
                <ANNOTATION_VALUE>помогли ему как - будто.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1185" ANNOTATION_REF="a815">
                <ANNOTATION_VALUE>Не спросивши, где есть он взял,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1186" ANNOTATION_REF="a816">
                <ANNOTATION_VALUE>не спрашивает где есть он груши взял.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1187" ANNOTATION_REF="a817">
                <ANNOTATION_VALUE>Сам есть собравши, или украдены есть, или что есть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1188" ANNOTATION_REF="a818">
                <ANNOTATION_VALUE>Помогли ему, положили</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1189" ANNOTATION_REF="a819">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1190" ANNOTATION_REF="a820">
                <ANNOTATION_VALUE>мальчик вперёд идёт, пешком идёт, ведёт медленно.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1191" ANNOTATION_REF="a821">
                <ANNOTATION_VALUE>Короб с грушами и с велосипедом ведёт,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1192" ANNOTATION_REF="a822">
                <ANNOTATION_VALUE>сам идёт дорога по.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1193" ANNOTATION_REF="a823">
                <ANNOTATION_VALUE>Мальчик,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1194" ANNOTATION_REF="a824">
                <ANNOTATION_VALUE>эти три мальчика, шли,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1195" ANNOTATION_REF="a825">
                <ANNOTATION_VALUE>(кар- ? ) идут,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1196" ANNOTATION_REF="a826">
                <ANNOTATION_VALUE>виднеется, что у него</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1197" ANNOTATION_REF="a827">
                <ANNOTATION_VALUE>никакого дела нет</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1198" ANNOTATION_REF="a828">
                <ANNOTATION_VALUE>толи играют, толи идут, толи что.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1199" ANNOTATION_REF="a829">
                <ANNOTATION_VALUE>Один мальчик так</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1200" ANNOTATION_REF="a830">
                <ANNOTATION_VALUE>лопаткой, как</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1201" ANNOTATION_REF="a831">
                <ANNOTATION_VALUE>мячиком играет.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1202" ANNOTATION_REF="a832">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1203" ANNOTATION_REF="a833">
                <ANNOTATION_VALUE>Шли, шли</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1204" ANNOTATION_REF="a834">
                <ANNOTATION_VALUE>эти три мальчика и видят</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1205" ANNOTATION_REF="a835">
                <ANNOTATION_VALUE>землле на, дороге на валяется его</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1206" ANNOTATION_REF="a836">
                <ANNOTATION_VALUE>шапка</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1207" ANNOTATION_REF="a837">
                <ANNOTATION_VALUE>это</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1208" ANNOTATION_REF="a838">
                <ANNOTATION_VALUE>из соломы сделана шапка.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1209" ANNOTATION_REF="a839">
                <ANNOTATION_VALUE>Ну и что, это надо отдать шапку обратно и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1210" ANNOTATION_REF="a840">
                <ANNOTATION_VALUE>распрямить,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1211" ANNOTATION_REF="a841">
                <ANNOTATION_VALUE>дать руки.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1212" ANNOTATION_REF="a842">
                <ANNOTATION_VALUE>Ознакомить его, что</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1213" ANNOTATION_REF="a843">
                <ANNOTATION_VALUE>подождать надо, он принесёт ему шапку,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1214" ANNOTATION_REF="a844">
                <ANNOTATION_VALUE>действительно бежал, принёс ему</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1215" ANNOTATION_REF="a845">
                <ANNOTATION_VALUE>шапку, дал, идёт,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1216" ANNOTATION_REF="a846">
                <ANNOTATION_VALUE>дорога есть твёрдая, слышно, как камни шаркают</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1217" ANNOTATION_REF="a847">
                <ANNOTATION_VALUE>ноги под да</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1218" ANNOTATION_REF="a848">
                <ANNOTATION_VALUE>шапку ему отдал.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1219" ANNOTATION_REF="a849">
                <ANNOTATION_VALUE>А этот</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1220" ANNOTATION_REF="a850">
                <ANNOTATION_VALUE>вороватый мальчишка дал им три груши и</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1221" ANNOTATION_REF="a851">
                <ANNOTATION_VALUE>больше не дал, потому что по одной.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1222" ANNOTATION_REF="a852">
                <ANNOTATION_VALUE>Груши есть даны,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1223" ANNOTATION_REF="a853">
                <ANNOTATION_VALUE>этот пришёл обратно, ноги повернул (Schneidersitz).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1224" ANNOTATION_REF="a854">
                <ANNOTATION_VALUE>Идут,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1225" ANNOTATION_REF="a855">
                <ANNOTATION_VALUE>груши едят</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1226" ANNOTATION_REF="a856">
                <ANNOTATION_VALUE>и подошли к тому</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1227" ANNOTATION_REF="a857">
                <ANNOTATION_VALUE>к тому месту, где человек груши собирает.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1228" ANNOTATION_REF="a858">
                <ANNOTATION_VALUE>А в это время человек вниз спустился,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1229" ANNOTATION_REF="a859">
                <ANNOTATION_VALUE>полный есть фартука корман,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1230" ANNOTATION_REF="a860">
                <ANNOTATION_VALUE>полный груш собран</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1231" ANNOTATION_REF="a861">
                <ANNOTATION_VALUE>и думает, положить нижний короб,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1232" ANNOTATION_REF="a862">
                <ANNOTATION_VALUE>пустой пустой есть туда положить.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1233" ANNOTATION_REF="a863">
                <ANNOTATION_VALUE>И смотрит, не может ничего понять,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1234" ANNOTATION_REF="a864">
                <ANNOTATION_VALUE>как так вышло, у него два короба было,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1235" ANNOTATION_REF="a865">
                <ANNOTATION_VALUE>полных короба,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1236" ANNOTATION_REF="a866">
                <ANNOTATION_VALUE>а осталось есть один.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1237" ANNOTATION_REF="a867">
                <ANNOTATION_VALUE>Не слышавши же, кто мимо шёл,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1238" ANNOTATION_REF="a868">
                <ANNOTATION_VALUE>и кто есть взял,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1239" ANNOTATION_REF="a869">
                <ANNOTATION_VALUE>не знает ничего,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1240" ANNOTATION_REF="a870">
                <ANNOTATION_VALUE>сидит, удивляется есть.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1241" ANNOTATION_REF="a871">
                <ANNOTATION_VALUE>Не знает,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1242" ANNOTATION_REF="a872">
                <ANNOTATION_VALUE>что делать.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1243" ANNOTATION_REF="a873">
                <ANNOTATION_VALUE></ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1244" ANNOTATION_REF="a874">
                <ANNOTATION_VALUE>Дети эти мимо,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1245" ANNOTATION_REF="a875">
                <ANNOTATION_VALUE>эти три мальчика,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1246" ANNOTATION_REF="a876">
                <ANNOTATION_VALUE>мимо шли груши-то кусали,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1247" ANNOTATION_REF="a877">
                <ANNOTATION_VALUE>человек них на смотрит, и думает,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1248" ANNOTATION_REF="a878">
